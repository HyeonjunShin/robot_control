<?xml version="1.0"?>
<robot name="m1013">

  <material name="DoosanWhite">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>

  <material name="DoosanBlue">
    <color rgba="0.0 0.2 0.6 1.0"/>
  </material>

  <link name="world"/>

  <joint name="fixed" type="fixed">
    <parent link="world"/>
    <child link="base_0"/>
  </joint>

  <link name="base_0">
    <inertial>
      <mass value="3.722"/>
      <origin xyz="-0.000025 -0.000854 0.026262" rpy="0 0 0"/>
      <inertia ixx="0.008311" ixy="-0.000016" ixz="-0.000000"
               iyy="0.008034" iyz="-0.000001" izz="0.014502"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="./visual/base.stl" scale="1 1 1"/>
      </geometry>
      <material name="DoosanWhite"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="./collision/base.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_1" type="revolute">
    <parent link="base_0"/>
    <child link="link_1"/>
    <origin rpy="0 0 0" xyz="0 0 0.1525"/>
    <axis xyz="0 0 1"/>
    <limit effort="10000" lower="-6.283" upper="6.283" velocity="1.571"/>
    <dynamics damping="5.0" friction="1.0"/>
  </joint>

  <link name="link_1">
    <inertial>
      <mass value="7.446"/>
      <origin xyz="0.000002 0.013897 0.002585" rpy="0 0 0"/>
      <inertia ixx="0.038493" ixy="-0.000000" ixz="0.000002"
              iyy="0.034668" iyz="-0.000227" izz="0.027562"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="./visual/link1.stl" scale="1 1 1"/>
      </geometry>
      <material name="DoosanWhite"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="./collision/link1.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin rpy="0 -1.5708 -1.5708" xyz="0 0.0345 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="10000" lower="-1.658" upper="1.658" velocity="1.571"/>
    <dynamics damping="5.0" friction="1.0"/>
  </joint>

  <link name="link_2">
    <inertial>
      <mass value="10.569"/>
      <origin xyz="0.266472 0.000005 0.165814" rpy="0 0 0"/>
      <inertia ixx="0.034551" ixy="-0.000013" ixz="0.000779"
              iyy="0.703166" iyz="-0.000001" izz="0.693952"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="./visual/link2.stl" scale="1 1 1"/>
      </geometry>
      <material name="DoosanWhite"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="./collision/link2.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin rpy="0 0 1.5708" xyz="0.62 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="10000" lower="-2.53" upper="2.53" velocity="1.571"/>
    <dynamics damping="5.0" friction="1.0"/>
  </joint>

  <link name="link_3">
    <inertial>
      <mass value="3.614"/> 
      <origin xyz="-0.000001 -0.003177 0.017743" rpy="0 0 0"/>
      <inertia ixx="0.011039" ixy="0.000001" ixz="-0.000000"
              iyy="0.007487" iyz="-0.000458" izz="0.009779"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="./visual/link3.stl" scale="1 1 1"/>
      </geometry>
      <material name="DoosanWhite"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="./collision/link3.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_4" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin rpy="1.5708 0 0" xyz="0 -0.559 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="1000000" lower="-6.283" upper="6.283" velocity="1.571"/>
    <dynamics damping="15.0" friction="2.0"/>
  </joint>

  <link name="link_4">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0"
               iyy="0.1" iyz="0.0" izz="0.1"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="./visual/link4.stl" scale="1 1 1"/>
      </geometry>
      <material name="DoosanWhite"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="./collision/link4.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_5" type="revolute">
    <parent link="link_4"/>
    <child link="link_5"/>
    <origin rpy="-1.5708 0 0" xyz="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="10000" lower="-2.356" upper="2.356" velocity="1.571"/>
    <dynamics damping="5.0" friction="1.0"/>
  </joint>

  <link name="link_5">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0"
               iyy="0.1" iyz="0.0" izz="0.1"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="./visual/link5.stl" scale="1 1 1"/>
      </geometry>
      <material name="DoosanWhite"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="./collision/link5.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_6" type="revolute">
    <parent link="link_5"/>
    <child link="link_6"/>
    <origin rpy="1.5708 0 0" xyz="0 -0.121 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="10000" lower="-6.283" upper="6.283" velocity="1.571"/>
    <dynamics damping="5.0" friction="1.0"/>
  </joint>

  <link name="link_6">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0"
               iyy="0.1" iyz="0.0" izz="0.1"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="./visual/link6.stl" scale="1 1 1"/>
      </geometry>
      <material name="DoosanBlue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="./collision/link6.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <joint name="gripper_joint" type="revolute"> 
    <parent link="link_6"/>
    <child link="gripper_link"/>
    <origin xyz="0 0 0.01" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0" upper="0" effort="100" velocity="0"/>
  </joint>

  <link name="gripper_link">
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder length="0.02" radius="0.02"/>
      </geometry>
      <material name="DoosanBlue"/>
    </visual>
   <collision name="gripper_collision"> 
      <geometry>
        <cylinder length="0.02" radius="0.02"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="base_0">
    <material>Gazebo/White</material>
  </gazebo>
  <gazebo reference="link_1">
    <material>Gazebo/White</material>
  </gazebo>
  <gazebo reference="link_2">
    <material>Gazebo/White</material>
  </gazebo>
  <gazebo reference="link_3">
    <material>Gazebo/White</material>
  </gazebo>
  <gazebo reference="link_4">
    <material>Gazebo/White</material>
  </gazebo>
  <gazebo reference="link_5">
    <material>Gazebo/White</material>
  </gazebo>
  <gazebo reference="link_6">
    <material>Gazebo/Blue</material>
  </gazebo>
  <gazebo reference="gripper_link">
    <material>Gazebo/Blue</material>
    <sensor name="gripper_contact_sensor" type="contact">
      <always_on>true</always_on>
      <update_rate>50</update_rate>
      <contact>
        <collision>gripper_link_fixed_joint_lump__gripper_collision_collision</collision>
      </contact>
      <topic>/gripper/contact</topic>
    </sensor>
  </gazebo>

  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="joint_1">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_2">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_3">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_4">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_5">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_6">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find uon_gz_sim_ros2)/config/ros2_controllers.yaml</parameters>
    </plugin>
  </gazebo>


</robot>